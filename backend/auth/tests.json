{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "username": "testuser99", "password": "pass123", "display_name": "Test User"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string", "user_id": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login existing user",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "username": "testuser99", "password": "pass123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Wrong password",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "username": "testuser99", "password": "wrong"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
